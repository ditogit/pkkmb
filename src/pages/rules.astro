---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Rules - PKKBN 2026">
  <main class="max-w-4xl mx-auto px-6 space-y-12 pt-12 pb-24">
    <div class="text-center space-y-4">
      <h1 class="text-4xl font-bold text-primary">Tata Tertib Peserta</h1>
      <p class="text-on-surface-variant">
        Peraturan dan pedoman kegiatan PKKBN UPN "Veteran" Yogyakarta
      </p>
    </div>

    <!-- Legal Foundation -->
    <div class="bg-surface-container-lowest p-6 rounded-2xl border border-outline-variant/10">
      <h2 class="text-xl font-bold text-primary mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined">gavel</span>
        Dasar Hukum
      </h2>
      <ul class="space-y-3 text-on-surface-variant">
        <li class="flex gap-3">
          <span class="material-symbols-outlined text-secondary text-sm mt-1">description</span>
          <span>Peraturan Rektor Nomor 15 Tahun 2023 tentang Pedoman Kegiatan Pengenalan Kehidupan Kampus Bela Negara Universitas Pembangunan Nasional "Veteran" Yogyakarta.</span>
        </li>
        <li class="flex gap-3">
          <span class="material-symbols-outlined text-secondary text-sm mt-1">description</span>
          <span>Peraturan Rektor Nomor 10 Tahun 2021 tentang Kode Etik Mahasiswa Universitas Pembangunan Nasional "Veteran" Yogyakarta.</span>
        </li>
      </ul>
    </div>

    <!-- Mandatory Rules -->
    <div class="bg-surface-container-lowest p-8 rounded-2xl border border-outline-variant/10">
      <h2 class="text-xl font-bold text-primary mb-6 flex items-center gap-2">
        <span class="material-symbols-outlined bg-secondary/10 text-secondary p-2 rounded-xl">check_circle</span>
        Kewajiban Peserta
      </h2>
      <p class="text-sm text-secondary font-semibold mb-4">
        Selama melaksanakan kegiatan, seluruh peserta <span class="bg-tertiary-fixed text-on-tertiary-fixed px-2 py-1 rounded font-bold">DIWAJIBKAN:</span>
      </p>
      <ul class="space-y-4">
        <li class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-secondary mt-1">check_box</span>
          <div>
            <h3 class="font-semibold">Melaksanakan kegiatan sesuai rencana yang telah ditetapkan.</h3>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-secondary mt-1">check_box</span>
          <div>
            <h3 class="font-semibold">Menjaga sikap dan perilaku dengan mengutamakan 5S:</h3>
            <ul class="mt-2 ml-6 space-y-1 text-sm text-on-surface-variant">
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
                Senyum
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
                Salam
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
                Sapa
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
                Sopan
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
                Santun
              </li>
            </ul>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-secondary mt-1">check_box</span>
          <div>
            <h3 class="font-semibold">Berpakaian rapi dan sopan sesuai dengan aturan berpakaian.</h3>
          </div>
        </li>
      </ul>
    </div>

    <!-- Prohibited Actions -->
    <div class="bg-surface-container-lowest p-8 rounded-2xl border border-error/20">
      <h2 class="text-xl font-bold text-error mb-6 flex items-center gap-2">
        <span class="material-symbols-outlined bg-error-container/50 text-error p-2 rounded-xl">cancel</span>
        Larangan Peserta
      </h2>
      <p class="text-sm text-error font-semibold mb-4">
        Selama melaksanakan kegiatan, seluruh peserta <span class="bg-error-container text-error px-2 py-1 rounded font-bold">DILARANG:</span>
      </p>
      <ul class="space-y-4">
        <li class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-error mt-1">close</span>
          <div>
            <h3 class="font-semibold">Perbuatan yang melanggar norma</h3>
            <p class="text-sm text-on-surface-variant">Melakukan tindakan yang dapat menyebarkan kebencian, unsur pornografi/porno aksi, dan provokasi SARA (Suku Agama Ras dan Antar Golongan).</p>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-error mt-1">close</span>
          <div>
            <h3 class="font-semibold">Kekerasan dan kata-kata kasar</h3>
            <p class="text-sm text-on-surface-variant">Melakukan tindakan kekerasan fisik, berkata-kata kasar dan keras.</p>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-error mt-1">close</span>
          <div>
            <h3 class="font-semibold">Atribut dan media tidak resmi</h3>
            <p class="text-sm text-on-surface-variant">Menggunakan atribut-atribut tambahan dan media selain yang telah ditetapkan.</p>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-error mt-1">close</span>
          <div>
            <h3 class="font-semibold">Penganiayaan</h3>
            <p class="text-sm text-on-surface-variant">Melakukan penganiayaan baik secara fisik dan mental.</p>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-error mt-1">close</span>
          <div>
            <h3 class="font-semibold">Tindakan asusila dan kejahatan seksual</h3>
            <p class="text-sm text-on-surface-variant">Melakukan tindakan asusila dan kejahatan seksual.</p>
          </div>
        </li>
      </ul>
    </div>

    <!-- Sanctions -->
    <div class="bg-slate-900 text-white p-8 rounded-2xl">
      <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
        <span class="material-symbols-outlined">warning</span>
        Sanksi Pelanggaran
      </h2>
      <div class="space-y-4">
        <div class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-tertiary-fixed-dim mt-1">info</span>
          <p>
            Sesuai dengan <strong>Peraturan Rektor Nomor 10 Tahun 2021</strong> tentang Kode Etik Mahasiswa.
          </p>
        </div>
        <div class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-tertiary-fixed-dim mt-1">local_police</span>
          <p>
            Pelanggaran hukum pidana akan diproses sesuai dengan peraturan perundang-undangan yang berlaku di <strong>Negara Kesatuan Republik Indonesia</strong>.
          </p>
        </div>
      </div>
    </div>
    <!-- Footer Note -->
    <div class="text-center italic text-on-surface-variant text-sm border-t border-outline-variant/20 pt-6">
      <p>Dokumen ini merupakan pedoman tata tertib yang wajib dipatuhi oleh seluruh peserta PKKBN UPN "Veteran" Yogyakarta.</p>
    </div>
  </main>
</MainLayout>
