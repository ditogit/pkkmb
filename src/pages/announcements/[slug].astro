---
import MainLayout from "../../layouts/MainLayout.astro";

export function getStaticPaths() {
  const announcements = [
    {
      slug: "prosedur-pengambilan-atribut-pkkbn",
      category: "Info Penting",
      categoryClass: "bg-tertiary-fixed text-on-tertiary-fixed",
      title: "Prosedur Pengambilan Atribut PKKBN",
      description: "Panduan teknis pengambilan kaos, topi, dan name tag peserta.",
      date: "12 Juli 2026",
      image: "https://lh3.googleusercontent.com/aida-public/AB6AXuCZ5oSkvfePHgRzMTOnedvXg5at0snXmqaAFE_WuRjnqJ_FP-a0PH3nfX5kNY9pqaIzHeYrxbA5m_KGczDX_e5pTGOlGbeCLLTED2OIUHPh42lneJYivGmp8WktTJkN1Y6GoXHM9onhjswAzxzwuJVY4ENL4KAZ6Ei2kLya2w8-iUGPnpbjEA62edVa-Wg2bDgLMrx98NYrAk0iIla0GdP21vObnX5H5Vxrguzo4BexZRqC1uHW6btFBWncKWjffZ5IUJoLpYcmnvNx",
