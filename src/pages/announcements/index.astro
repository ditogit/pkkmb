---
import MainLayout from "../../layouts/MainLayout.astro";
import AnnouncementList from "../../components/announcements/AnnouncementList.astro";
---

<MainLayout title="Announcements - PKKMB 2026">
  <main
    class="max-w-4xl mx-auto px-4 md:px-6 space-y-8 md:space-y-12 pt-8 md:pt-12 pb-16 md:pb-24">
    <div class="text-center space-y-3 md:space-y-4">
      <h1 class="text-2xl md:text-4xl font-bold text-primary">Pengumuman</h1>
      <p class="text-sm md:text-base text-on-surface-variant">
        Informasi terbaru seputar kegiatan PKKMB Universitas Merah Putih Tahun
        2026
      </p>
    </div>

    <AnnouncementList />
  </main>
</MainLayout>
