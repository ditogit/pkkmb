---
const navItems = [
  { href: "/pkkmb", label: "Home" },
//   { href: "/pkkmb/schedule", label: "Schedule" },
//   { href: "/pkkmb/groups", label: "Groups" },
{ href: "/pkkmb/rules", label: "Tata Tertib" },
{ href: "/pkkmb/announcements", label: "Info" },
  { href: "/pkkmb/faq", label: "FAQ" },
//   { href: "/pkkmb/guide", label: "Guide" },
];

const currentPath = Astro.url.pathname;
---

<nav class="bg-white/80 backdrop-blur-xl top-0 sticky z-50 shadow-sm shadow-blue-900/5 w-full">
  <div class="flex justify-between items-center px-4 md:px-6 py-3 md:py-4 max-w-full md:max-w-7xl mx-auto">
    <a
      href="/pkkmb"
      class="text-lg md:text-xl font-bold bg-gradient-to-br from-blue-900 to-blue-700 bg-clip-text text-transparent font-headline">
      PKKBN 2026
    </a>
    <div class="hidden md:flex items-center space-x-6 md:space-x-8 font-headline font-semibold tracking-tight">
      {navItems.map((item) => (
        <a
          class:list={[
            "pb-1 transition-colors",
            currentPath === item.href
              ? "text-blue-700 border-b-2 border-blue-700"
              : "text-slate-600 hover:text-blue-500"
          ]}
          href={item.href}>
          {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>
