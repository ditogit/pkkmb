      { time: "09:00 - 12:00", title: "Olahraga & Competitive Games", location: "Stadion" },
      { time: "12:00 - 13:00", title: "ISHOMA", location: "Shelter A" },
      { time: "13:00 - 15:00", title: "Outbound & Team Building", location: "Halaman Campus" },
      { time: "15:00 - 17:00", title: "Closing Ceremony Outdoor", location: "Amphitheater" }
