    events: [
      { time: "08:00 - 10:00", title: "Pengenalan Kajur & Staff", location: "Ruang Prodi" },
      { time: "10:00 - 12:00", title: "Kurikulum & Sistem Kredit", location: "Kelas A" },
      { time: "12:00 - 13:00", title: "ISHOMA", location: "Kantin Prodi" },
