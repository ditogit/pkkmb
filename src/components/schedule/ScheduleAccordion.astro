    ]
  },
  {
    day: "2",
    date: "12",
    month: "Agustus",
    title: "Kegiatan Fakultas",
    description: "Kegiatan yang diadakan oleh masing-masing fakultas",
    events: [
      { time: "08:00 - 10:00", title: "Pengenalan Dekanat & Visi Misi", location: "Gedung Dekanat" },
