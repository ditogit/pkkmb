      { time: "09:00 - 10:30", title: "Pemutakhiran File Kegiatan", location: "Hall Utama" },
      { time: "10:30 - 11:00", title: "Sambutan Dean of Students", location: "Aula Utama" },
      { time: "11:00 - 12:00", title: "Pengumuman Kelulusan & Award", location: "Aula Utama" },
