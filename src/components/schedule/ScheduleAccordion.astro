---

<div class="space-y-6" x-data="{ activeTab: 0 }">
  <!-- Tab Navigation -->
  <div class="bg-surface-container-low p-2 rounded-full flex overflow-x-auto scrollbar-hide gap-2">
    {schedules.map((schedule, index) => (
      <button
        x-on:click={`activeTab = ${index}`}
        :class={`activeTab === ${index} ? 'bg-white shadow-sm text-primary' : 'text-on-surface-variant hover:text-primary'`}
        class="flex-1 min-w-[100px] py-3 px-4 rounded-full text-sm font-bold transition-all whitespace-nowrap">
        <span class="block text-xs font-normal opacity-70">Hari {schedule.day}</span>
        <span class="block">{schedule.date} {schedule.month}</span>
      </button>
    ))}
  </div>

  <!-- Tab Content -->
  {schedules.map((schedule, index) => (
    <div x-show={`activeTab === ${index}`} x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 transform translate-y-2" x-transition:enter-end="opacity-100 transform translate-y-0">
      <div class="bg-surface-container-lowest p-6 rounded-2xl shadow-sm border border-outline-variant/10">
        <div class="flex items-start justify-between mb-6 pb-6 border-b border-outline-variant/10">
          <div>
            <h3 class="text-2xl font-bold text-primary">Hari {schedule.day}</h3>
            <p class="text-on-surface-variant">{schedule.description}</p>
          </div>
          <div class="text-center bg-primary/10 px-4 py-2 rounded-xl">
            <div class="text-2xl font-bold text-primary">{schedule.date}</div>
            <div class="text-[10px] font-bold uppercase text-outline">{schedule.month}</div>
          </div>
        </div>

        <h4 class="font-bold text-lg mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-secondary">schedule</span>
          Detail Kegiatan
        </h4>

        <div class="space-y-4">
          {schedule.events.map((event) => (
            <div class="flex gap-4 p-4 bg-surface-container-low rounded-xl hover:bg-surface-container transition-colors">
              <div class="text-center min-w-[70px] flex-shrink-0">
                <div class="text-sm font-bold text-primary bg-primary/10 px-2 py-1 rounded-lg">{event.time}</div>
              </div>
              <div class="flex-1">
                <h5 class="font-bold">{event.title}</h5>
                <p class="text-sm text-on-surface-variant flex items-center gap-1 mt-1">
                  <span class="material-symbols-outlined text-xs">location_on</span>
                  {event.location}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  ))}
</div>
