    events: [
      { time: "07:00 - 08:00", title: "Registrasi & Verifikasi Peserta", location: "Lobby Utama" },
      { time: "08:00 - 10:00", title: "Upacara Pembukaan PKKMB", location: "Lapangan Rektorat" },
      { time: "10:00 - 10:30", title: "Sambutan Rector & Dekan", location: "Aula Lantai 2" },
      { time: "10:30 - 12:00", title: "Stadium General", location: "Gedung A" },
      { time: "12:00 - 13:00", title: "ISHOMA", location: "Kantin Pusat" },
      { time: "13:00 - 15:00", title: "Penguatan Nilai Bela Negara", location: "Aula Utama" },
