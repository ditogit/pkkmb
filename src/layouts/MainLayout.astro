---
import '../styles/global.css';
import Navbar from '../components/navbar/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import MobileNav from '../components/navbar/MobileNav.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html class="light" lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- PWA: required for Chrome install prompt & browser chrome colouring -->
    <meta name="theme-color" content="#0f172a" />
    <!-- PWA: iOS standalone support -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="PKKMB" />
    <link rel="apple-touch-icon" href="/pkkmb/icons/icon-192.png" />

    <ViewTransitions />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet" />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet" />
    <style>
      body {
        font-family: 'Manrope', sans-serif;
        background-color: #f7f9fb;
        color: #191c1e;
      }
      h1, h2, h3, .font-headline {
        font-family: 'Plus Jakarta Sans', sans-serif;
      }
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>
  </head>
  <body class="bg-surface text-on-surface">
    <Navbar />
    <slot />
    <Footer />
    <MobileNav />

    <!-- PWA Install Banner -->
    <div
      id="pwa-install-banner"
      class="fixed bottom-0 left-0 right-0 z-50 hidden"
    >
      <div class="m-4 bg-surface-container rounded-2xl shadow-xl p-4 flex items-center gap-4 border border-outline-variant">
        <img src="/pkkmb/icons/icon-192.png" alt="PKKMB icon" class="w-12 h-12 rounded-xl flex-shrink-0" />
        <div class="flex-1 min-w-0">
          <p class="font-bold text-sm text-on-surface">Pasang Aplikasi PKKMB</p>
          <p class="text-xs text-on-surface-variant">Akses cepat & tersedia offline</p>
        </div>
        <div class="flex gap-2 flex-shrink-0">
          <button
            id="pwa-install-dismiss"
            class="px-3 py-1.5 text-xs font-semibold text-on-surface-variant rounded-lg hover:bg-surface-container-high transition-colors"
          >
            Nanti
          </button>
          <button
            id="pwa-install-btn"
            class="px-3 py-1.5 text-xs font-semibold bg-primary text-on-primary rounded-lg hover:opacity-90 transition-opacity"
          >
            Pasang
          </button>
        </div>
      </div>
    </div>

    <script>
      import Alpine from 'alpinejs';
      window.Alpine = Alpine;
      Alpine.start();
    </script>

    <!-- PWA Install Prompt Handler -->
    <script>
      let deferredPrompt: any = null;
      const banner = document.getElementById('pwa-install-banner');
      const installBtn = document.getElementById('pwa-install-btn');
      const dismissBtn = document.getElementById('pwa-install-dismiss');

      // Capture the install prompt before the browser shows it
      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredPrompt = e;
        if (banner) banner.classList.remove('hidden');
      });

      // User clicked "Pasang"
      installBtn?.addEventListener('click', async () => {
        if (!deferredPrompt) return;
        deferredPrompt.prompt();
        const { outcome } = await deferredPrompt.userChoice;
        deferredPrompt = null;
        if (banner) banner.classList.add('hidden');
      });

      // User clicked "Nanti"
      dismissBtn?.addEventListener('click', () => {
        if (banner) banner.classList.add('hidden');
        // Suppress for this session
        sessionStorage.setItem('pwa-banner-dismissed', '1');
      });

      // Don't show banner again if dismissed this session
      if (sessionStorage.getItem('pwa-banner-dismissed')) {
        if (banner) banner.classList.add('hidden');
      }

      // Hide banner once installed
      window.addEventListener('appinstalled', () => {
        if (banner) banner.classList.add('hidden');
        deferredPrompt = null;
      });
    </script>
  </body>
</html>
